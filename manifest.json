{
  "manifest_version": 3,
  "name": "SMU eCampus Dashboard",
  "version": "1.0.0",
  "description": "SMU eCampus 과목별 과제/강의/토론/자료를 한눈에 보는 확장 프로그램",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://ecampus.smu.ac.kr/*"],
  "content_scripts": [
    {
      "matches": ["https://ecampus.smu.ac.kr/*"],
      "js": ["dist/content.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SMU eCampus Dashboard",
    "default_popup": "dist/popup.html"
  }
}
